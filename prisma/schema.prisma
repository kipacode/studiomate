generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  employee
  intern
  freelancer
}

enum UserStatus {
  active
  inactive
}

model User {
  id              String       @id @default(cuid())
  name            String
  username        String       @unique
  email           String       @unique
  password        String
  role            UserRole     @default(intern)
  status          UserStatus   @default(active)
  birthDate       String?
  avatar          String?
  mood            String?
  internshipStart String?
  internshipEnd   String?
  homeLat         Float?
  homeLng         Float?
  homeLabel       String?
  createdAt       DateTime     @default(now())

  attendances     Attendance[]
}

model Location {
  id           String  @id @default(cuid())
  label        String
  address      String
  lat          Float
  lng          Float
  radiusMeters Int
  createdBy    String
  isActive     Boolean @default(true)
}

model Attendance {
  id           String    @id @default(cuid())
  userId       String
  date         String
  checkInTime  DateTime?
  checkOutTime DateTime?
  qrTokenUsed  String
  isLate       Boolean   @default(false)
  flagged      Boolean   @default(false)
  flagNote     String?
  status       String    @default("check-in")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model QRToken {
  id        String   @id @default(cuid())
  token     String   @unique
  validDate String
  createdBy String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}
